{
  "info": {
    "name": "Smart Campus API",
    "_postman_id": "sc-api-2026",
    "description": "IT3030 PAF Assignment – Smart Campus Operations Hub API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Test User\",\"email\":\"test@sliit.lk\",\"password\":\"test123\"}" }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.collectionVariables.set('token', pm.response.json().token);"] }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"admin@sliit.lk\",\"password\":\"admin123\"}" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Facilities",
      "item": [
        {
          "name": "Get All Facilities",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/facilities?type=LAB&status=ACTIVE", "query": [
              { "key": "type", "value": "LAB" }, { "key": "status", "value": "ACTIVE" }
            ]},
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Facility",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/facilities",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\":\"Computer Lab A-101\",\"type\":\"LAB\",\"capacity\":40,\"location\":\"Block A\",\"availabilityWindows\":\"8AM-8PM\",\"status\":\"ACTIVE\"}" }
          }
        },
        {
          "name": "Update Facility Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/facilities/FACILITY_ID/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"status\":\"OUT_OF_SERVICE\"}" }
          }
        },
        {
          "name": "Delete Facility",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/facilities/FACILITY_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"facilityId\":\"FACILITY_ID\",\"bookingDate\":\"2026-05-01\",\"startTime\":\"09:00\",\"endTime\":\"11:00\",\"purpose\":\"Group study\",\"attendees\":10}" }
          }
        },
        {
          "name": "Get All Bookings (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Check Conflicts",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings/check-conflicts",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"facilityId\":\"FACILITY_ID\",\"bookingDate\":\"2026-05-01\",\"startTime\":\"09:00\",\"endTime\":\"11:00\"}" }
          }
        },
        {
          "name": "Approve Booking",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/bookings/BOOKING_ID/approve",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"reason\":\"Approved for group study session\"}" }
          }
        },
        {
          "name": "Reject Booking",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/bookings/BOOKING_ID/reject",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"reason\":\"Room already reserved for exam\"}" }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/bookings/BOOKING_ID/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tickets",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Projector not working" },
                { "key": "category", "value": "EQUIPMENT" },
                { "key": "description", "value": "Ceiling projector shows blank screen" },
                { "key": "priority", "value": "HIGH" },
                { "key": "location", "value": "Block A, Lab 101" }
              ]
            }
          }
        },
        {
          "name": "Get All Tickets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tickets",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get My Tickets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tickets/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Ticket Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tickets/TICKET_ID/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"status\":\"IN_PROGRESS\",\"notes\":\"Technician dispatched\"}" }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tickets/TICKET_ID/comments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"text\":\"Parts have been ordered, ETA 2 days\"}" }
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/tickets/TICKET_ID/comments/COMMENT_ID",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/notifications",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/notifications/read-all",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/users/USER_ID/role",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"role\":\"TECHNICIAN\"}" }
          }
        }
      ]
    }
  ]
}
